---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { IdToSlug } from "../../utils/hash";
import PostLayout from "../../layouts/PostLayout.astro";
import { render } from "astro:content";
import { fetchApiPosts, fetchApiPostBySlug, renderMarkdown } from "../../utils/api";

export async function getStaticPaths() {
  const postEntries = await getCollection("posts");
  const localPaths = postEntries.map((entry) => ({
    params: { slug: IdToSlug(entry.id) },
    props: { entry, isApi: false, contentHtml: "" },
  }));

  const apiPosts = await fetchApiPosts();
  const apiPaths = [];
  for (const post of apiPosts) {
    const fullPost = await fetchApiPostBySlug(post.slug);
    if (fullPost) {
      // Map API post to match entry structure
      const mappedEntry = {
        id: fullPost.slug,
        slug: fullPost.slug,
        data: {
          title: fullPost.title,
          published: new Date(fullPost.published_at),
          category: fullPost.category,
          tags: fullPost.tags,
          description: fullPost.summary,
          cover: fullPost.cover_url,
          seo_title: fullPost.seo_title || "",
          meta_description: fullPost.meta_description || "",
          author: "SilentFlare",
          licenseName: undefined,
          licenseUrl: undefined,
          sourceLink: undefined,
        }
      };
      apiPaths.push({
        params: { slug: fullPost.slug },
        props: {
          entry: mappedEntry,
          isApi: true,
          contentHtml: renderMarkdown(fullPost.content_markdown || ""),
        },
      });
    }
  }

  return [...localPaths, ...apiPaths];
}

const { entry, isApi, contentHtml } = Astro.props;

const seoTitle = entry.data.seo_title || entry.data.title;
const metaDescription = entry.data.meta_description || entry.data.description || "";

let Content = null;
if (!isApi) {
  const rendered = await render(entry as CollectionEntry<"posts">);
  Content = rendered.Content;
}
---

{
  !entry.data.licenseName && (
    <PostLayout
      title={entry.data.title}
      subTitle={entry.data.description}
      bannerImage={entry.data.cover}
      published={entry.data.published}
      seoTitle={seoTitle}
      metaDescription={metaDescription}
      category={entry.data.category}
      tags={entry.data.tags}
    >
      <div
        class="hidden"
        data-pagefind-body
        data-pagefind-weight="10"
        data-pagefind-meta="title"
      >
        {entry.data.title}
      </div>
      <div data-pagefind-body>
        {isApi ? (
          <Fragment set:html={contentHtml} />
        ) : (
          Content && <Content />
        )}
      </div>
    </PostLayout>
  )
}
{
  entry.data.licenseName && (
    <PostLayout
      title={entry.data.title}
      subTitle={entry.data.description}
      bannerImage={entry.data.cover}
      published={entry.data.published}
      license={{ name: entry.data.licenseName, url: entry.data.licenseUrl }}
      author={entry.data.author}
      sourceLink={entry.data.sourceLink}
      seoTitle={seoTitle}
      metaDescription={metaDescription}
      category={entry.data.category}
      tags={entry.data.tags}
    >
      <div
        class="hidden"
        data-pagefind-body
        data-pagefind-weight="10"
        data-pagefind-meta="title"
      >
        {entry.data.title}
      </div>
      <div data-pagefind-body>
        {isApi ? (
          <Fragment set:html={contentHtml} />
        ) : (
          Content && <Content />
        )}
      </div>
    </PostLayout>
  )
}
